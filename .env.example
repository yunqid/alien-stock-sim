# Copy this file to `.env` and fill in your own values.
# The app boots and shows the landing page without these, but headline
# generation (Gemini), Google login, and the Alpha Vantage price nudge
# each need their corresponding key to work.

# Google Gemini API key — used for AI-generated news headlines.
GEMINI_API_KEY=

# Google OAuth client (Web application) — used for "Sign in with Google".
# Create one at https://console.cloud.google.com/auth/clients and add
# http://localhost:8000/accounts/google/login/callback/ as a redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Alpha Vantage free API key — real-world quote nudges. Optional.
ALPHAVANTAGE_API_KEY=
